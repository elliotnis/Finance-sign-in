# For normal development and VPS deployment, run the app with Docker Compose.
# Docker Compose starts the database service automatically.

# Optional
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Passwordless email login (HKUST email code) ----
# Required for the "Sign in with HKUST email" flow. Use a Gmail account and a
# Gmail App Password (https://myaccount.google.com/apppasswords) — NOT your
# normal Gmail password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASSWORD=your-16-char-gmail-app-password
# SMTP_FROM=HKUST FINA Portal <your-gmail@gmail.com>
# How long sign-in codes stay valid (minutes). Default 15.
# MAGIC_LINK_TTL_MINUTES=15
# Minimum delay between code requests for the same email/scope (15-300 seconds).
# MAGIC_LINK_REQUEST_COOLDOWN_SECONDS=60
# Challenge bearer sessions expire after this many hours (1-72). Default 12.
# TRADING_SESSION_TTL_HOURS=12

# ---- Normal portal admin accounts ----
# Comma-separated emails allowed to manage classes and portal data.
# ADMIN_EMAILS=alice@connect.ust.hk,bob@connect.ust.hk

# ---- Youth Financetopia gamemaster accounts ----
# This separate list controls the challenge's gamemaster one-time-code login.
# Do not add ordinary portal admins here unless they also run the event.
# GAMEMASTER_EMAILS=cylaucb@connect.ust.hk,mikiyeung@ust.hk,mhman@connect.ust.hk,firstacforbks@gmail.com,marcoleung0713@gmail.com,mayeechunandy@gmail.com
# TRADING_PARTICIPANT_EMAILS=cylaucb@connect.ust.hk,mikiyeung@ust.hk,mhman@connect.ust.hk,firstacforbks@gmail.com,marcoleung0713@gmail.com,mayeechunandy@gmail.com
