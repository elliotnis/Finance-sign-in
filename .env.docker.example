# Optional overrides for docker compose (copy to .env in this directory)
# FRONTEND_PORT=8080
# If the API is not on localhost:8000 from the browser's perspective, set:
# VITE_API_URL=http://your-host:8000

# Supabase (required for the API — same project as your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Recommended for the backend: Settings → API → service_role (bypasses RLS for server-side CRUD)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: extra browser origins for CORS (comma-separated)
# CORS_ORIGINS=https://your-frontend.example.com
