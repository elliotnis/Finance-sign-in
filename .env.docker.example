# Optional overrides for docker compose (copy to `.env` in the repo root)
# FRONTEND_PORT=8080
# Dedicated Youth Financetopia frontend.
# TRADING_SIM_PORT=4173

# The VPS deployment serves the API through the frontend at /api.
# VITE_API_URL=/api

# Optional: extra browser origins for CORS (comma-separated). If unset, see `backend/main.py` defaults.
# CORS_ORIGINS=https://your-frontend.example.com

# ---- Passwordless email login (HKUST magic link) ----
# Use a Gmail account and a Gmail App Password (NOT your real password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASSWORD=your-16-char-gmail-app-password
# SMTP_FROM=HKUST FINA Portal <your-gmail@gmail.com>
# Where the user lands when they click the link. Must be the public frontend URL.
# FRONTEND_URL=http://localhost:8080
# MAGIC_LINK_TTL_MINUTES=15
# Minimum delay between code requests for the same email/scope (15-300 seconds).
# MAGIC_LINK_REQUEST_COOLDOWN_SECONDS=60
# Youth Financetopia bearer session lifetime, in hours (1-72).
# TRADING_SESSION_TTL_HOURS=12

# ---- Normal portal admin accounts ----
# ADMIN_EMAILS=alice@connect.ust.hk,bob@connect.ust.hk

# ---- Youth Financetopia gamemaster accounts ----
# This is intentionally separate from ADMIN_EMAILS. These hosts receive the
# gamemaster one-time-code login and can run competition rounds.
# GAMEMASTER_EMAILS=cylaucb@connect.ust.hk,mikiyeung@ust.hk,mhman@connect.ust.hk,firstacforbks@gmail.com,marcoleung0713@gmail.com,mayeechunandy@gmail.com
# TRADING_PARTICIPANT_EMAILS=cylaucb@connect.ust.hk,mikiyeung@ust.hk,mhman@connect.ust.hk,firstacforbks@gmail.com,marcoleung0713@gmail.com,mayeechunandy@gmail.com
