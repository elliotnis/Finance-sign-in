# Optional overrides for docker compose (copy to `.env` in the repo root)
# FRONTEND_PORT=8080

# MongoDB connection string for the API container (default uses the Compose `mongo` service)
# MONGODB_URL=mongodb://mongo:27017

# If the API is not on localhost:8000 from the browser's perspective, set:
# VITE_API_URL=http://your-host:8000

# Optional: extra browser origins for CORS (comma-separated). If unset, see `backend/main.py` defaults.
# CORS_ORIGINS=https://your-frontend.example.com
